# ─────────────────────────────────────────────────────
#   Science Bot — Environment Configuration
# ─────────────────────────────────────────────────────
# انسخ هذا الملف إلى .env وأضف قيمك الخاصة

# ══════════════════════════════════════════════
#   التوكن — مطلوب
# ══════════════════════════════════════════════
# احصل عليه من @BotFather في تيليغرام
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ══════════════════════════════════════════════
#   OWNER_ID — مالك البوت (أهم إعداد)
# ══════════════════════════════════════════════
# معرفك الشخصي في تيليغرام — للحصول عليه:
# 1. افتح @userinfobot
# 2. أرسل /start
# 3. انسخ الرقم الظاهر هنا
OWNER_ID=YOUR_TELEGRAM_USER_ID_HERE

# ══════════════════════════════════════════════
#   ADMIN_IDS — مشرفون إضافيون (اختياري)
# ══════════════════════════════════════════════
# يمكن إضافة أكثر من مشرف بفصلهم بفاصلة
# مثال: ADMIN_IDS=111111,222222,333333
ADMIN_IDS=

# ══════════════════════════════════════════════
#   إعدادات اختيارية
# ══════════════════════════════════════════════
# قناة الوجهة الافتراضية (يمكن تغييرها عبر /setdest)
# استخدم المعرف الرقمي مثل: -1001234567890
DESTINATION_CHANNEL=

# مسار قاعدة البيانات
DATABASE_PATH=data/science_bot.db

# حساسية الكشف: 1(منخفض) إلى 5(عالي) — الافتراضي 2
CLASSIFICATION_THRESHOLD=2
